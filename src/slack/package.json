{
  "name": "@microagents/mcp-server-slack",
  "version": "0.0.2",
  "description": "MCP server for interacting with Slack",
  "license": "MIT",
  "author": "Microagents (https://microagents.dev)",
  "contributors": [
    "Anthropic, PBC (https://anthropic.com) - Original author"
  ],
  "homepage": "https://microagents.dev",
  "bugs": "https://github.com/microagents/mcp-servers/issues",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./definitions": {
      "types": "./dist/definitions/index.d.ts",
      "import": "./dist/definitions/index.js"
    }
  },
  "bin": {
    "mcp-server-slack": "dist/run.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && shx chmod +x dist/*.js",
    "prepare": "npm run build",
    "watch": "tsc --watch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.0.1"
  },
  "devDependencies": {
    "@types/node": "^22",
    "shx": "^0.3.4",
    "typescript": "^5.6.2"
  }
}